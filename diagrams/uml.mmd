classDiagram
    %% PawPal+ Pet Management System UML Class Diagram
    %% Task: single activity | Pet: stores details and tasks | Owner: manages pets
    %% Scheduler: the "brain" that retrieves, organizes, and manages tasks across pets

    class Task {
        -task_id: str
        -title: str
        -description: str
        -duration_minutes: int
        -priority: str
        -frequency: str
        -is_completed: bool
        +get_details() dict
        +mark_complete() void
        +update_priority(priority: str) void
    }

    class Pet {
        -pet_id: str
        -name: str
        -species: str
        -breed: str
        -age: int
        -health_notes: str
        -tasks: list~Task~
        +add_task(task: Task) void
        +remove_task(task_id: str) void
        +get_tasks() list~Task~
        +get_info() dict
    }

    class Owner {
        -owner_id: str
        -name: str
        -email: str
        -pets: list~Pet~
        +add_pet(pet: Pet) void
        +remove_pet(pet_id: str) void
        +get_pets() list~Pet~
        +get_all_tasks() list~Task~
    }

    class Scheduler {
        -scheduler_id: str
        -owner: Owner
        +retrieve_all_tasks() list~Task~
        +organize_tasks(tasks: list~Task~) list~Task~
        +generate_schedule(date: date) dict
        +prioritize_tasks(tasks: list~Task~) list~Task~
        +get_schedule_summary(date: date) str
    }

    %% Relationships
    Owner "1" --> "*" Pet : manages
    Pet "1" --> "*" Task : stores
    Scheduler "1" --> "1" Owner : organizes for
