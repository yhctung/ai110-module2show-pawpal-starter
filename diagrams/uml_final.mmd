classDiagram
    %% PawPal+ Pet Management System UML Class Diagram (Final Implementation)
    %% Task: single pet care activity | Pet: stores details and manages tasks | Owner: manages pets
    %% Scheduler: the "brain" that retrieves, organizes, filters, and manages tasks across pets

    class TaskStatus {
        <<enumeration>>
        PENDING
        COMPLETED
    }

    class Task {
        -task_id: str
        -title: str
        -description: str
        -duration_minutes: int
        -priority: str
        -frequency: str
        -pet_id: str
        -due_date: datetime
        -status: TaskStatus
        -last_completed: datetime
        +get_details() dict
        +mark_complete() void
        +create_next_occurrence() Task
        +is_overdue() bool
    }

    class Pet {
        -pet_id: str
        -name: str
        -species: str
        -owner_id: str
        -tasks: list~Task~
        +add_task(task: Task) void
        +get_tasks() list~Task~
    }

    class Owner {
        -owner_id: str
        -name: str
        -pets: list~Pet~
        +add_pet(pet: Pet) void
        +get_pets() list~Pet~
        +get_all_tasks() list~Task~
    }

    class Scheduler {
        -scheduler_id: str
        -owner: Owner
        +_get_tasks_for_date(date: datetime) list~Task~
        +generate_schedule(date: datetime) dict
        +prioritize_tasks(tasks: list~Task~) list~Task~
        +sort_by_time(tasks: list~Task~) list~Task~
        +filter_tasks(tasks: list~Task~, status: str, pet_name: str) list~Task~
        +complete_task(task: Task) Task
        +detect_conflicts(date: datetime) list
        +get_schedule_summary(date: datetime) str
    }

    %% Relationships
    Owner "1" --> "*" Pet : manages
    Pet "1" --> "*" Task : contains
    Task "many" --> "1" TaskStatus : has
    Scheduler "1" --> "1" Owner : organizes for
    Scheduler "1" --> "*" Task : operates on
